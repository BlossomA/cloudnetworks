# Copy this file to terraform.tfvars and fill in values
# Do NOT commit terraform.tfvars to git

aws_region               = "us-east-1"
project_name             = "multi-cloud-net"
environment              = "lab"

hub_vpc_cidr             = "10.0.0.0/16"
hub_public_subnet_cidr   = "10.0.1.0/24"
hub_private_subnet_cidr  = "10.0.2.0/24"

spoke1_vpc_cidr          = "10.1.0.0/16"
spoke1_public_subnet_cidr  = "10.1.1.0/24"
spoke1_private_subnet_cidr = "10.1.2.0/24"

spoke2_vpc_cidr          = "10.2.0.0/16"
spoke2_public_subnet_cidr  = "10.2.1.0/24"
spoke2_private_subnet_cidr = "10.2.2.0/24"

instance_type            = "t3.micro"
key_pair_name            = "your-aws-keypair-name"  # Must exist in the AWS account
